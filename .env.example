PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/tripxto
JWT_SECRET=change-me-to-a-long-random-string-in-production
# Optional: leave empty to disable Redis (no response caching)
REDIS_URL=redis://127.0.0.1:6379
REDIS_TRIPS_LIST_TTL_SEC=45
REDIS_ITINERARY_TTL_SEC=90
# If true, OTP send response includes the code (dev only; never enable in production)
DEV_RETURN_OTP=true
