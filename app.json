{
  "expo": {
    "name": "TripXto",
    "slug": "tripxto-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/tripxto-brand.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/tripxto-brand.png",
      "resizeMode": "contain",
      "backgroundColor": "#1155cc"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1155cc",
        "foregroundImage": "./assets/tripxto-brand-fg.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.vishnu2025.tripxtomobile"
    },
    "web": {
      "favicon": "./assets/tripxto-brand.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "3b8d4bae-829a-4173-9b70-20b60dc4d7e1"
      }
    }
  }
}
